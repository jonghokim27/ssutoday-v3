{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "googleServicesFile": "$GOOGLE_SERVICES_JSON" },
      "ios": { "googleServicesFile": "$GOOGLE_SERVICE_INFO_PLIST" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "googleServicesFile": "$GOOGLE_SERVICES_JSON" },
      "ios": { "googleServicesFile": "$GOOGLE_SERVICE_INFO_PLIST" }
    },
    "production": {
      "autoIncrement": true,
      "android": { "googleServicesFile": "$GOOGLE_SERVICES_JSON" },
      "ios": { "googleServicesFile": "$GOOGLE_SERVICE_INFO_PLIST" }
    }
  },
  "submit": {
    "production": {}
  }
}
